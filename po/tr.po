msgstr "Parolayı biraz daha değiştirmeyi deneyin."

#: src/disks/gdu-create-password-page.c:47
msgctxt "Password hint"
msgid "Try to avoid some of the words included in the password."
msgstr "Paroladaki bazı sözcüklerden kaçınmayı deneyin."

#: src/disks/gdu-create-password-page.c:51
msgctxt "Password hint"
msgid "Try to avoid common words."
msgstr "Yaygın sözcükler olmadan deneyin."

#: src/disks/gdu-create-password-page.c:53
msgctxt "Password hint"
msgid "Try to avoid reordering existing words."
msgstr "Aynı sözcükleri kullanmadan deneyin."

#: src/disks/gdu-create-password-page.c:55
msgctxt "Password hint"
msgid "Try to use more numbers."
msgstr "Daha çok sayı kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:57
msgctxt "Password hint"
msgid "Try to use more uppercase letters."
msgstr "Daha çok büyük harf kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:59
msgctxt "Password hint"
msgid "Try to use more lowercase letters."
msgstr "Daha çok küçük harf kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:61
msgctxt "Password hint"
msgid "Try to use more special characters, like punctuation."
msgstr "Noktalama işaretleri gibi daha çok özel karakter kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:63
msgctxt "Password hint"
msgid "Try to use a mixture of letters, numbers and punctuation."
msgstr "Harf, sayı ve noktalama işareti karışımları kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:65
msgctxt "Password hint"
msgid "Try to avoid repeating the same character."
msgstr "Aynı karakterleri yinelemeden deneyin."

#: src/disks/gdu-create-password-page.c:67
msgctxt "Password hint"
msgid ""
"Try to avoid repeating the same type of character: you need to mix up "
"letters, numbers and punctuation."
msgstr ""
"Aynı türdeki karakterleri yinelemeden deneyin: harfleri, sayıları ve "
"noktalama işaretlerini karıştırmalısınız."

#: src/disks/gdu-create-password-page.c:69
msgctxt "Password hint"
msgid "Try to avoid sequences like 1234 or abcd."
msgstr "1234 ya da abcd gibi sıralamalardan kaçınarak deneyin."

#: src/disks/gdu-create-password-page.c:71
msgctxt "Password hint"
msgid "Mix uppercase and lowercase and try to use a number or two."
msgstr ""
"Büyük ve küçük harfleri karıştırın ve bir ya da iki sayı kullanmayı deneyin."

#: src/disks/gdu-create-password-page.c:73
msgctxt "Password hint"
msgid ""
"Adding more letters, numbers and punctuation will make the password stronger."
msgstr ""
"Daha çok harf, sayı ve noktalama işareti kullanmak parolanızı daha güçlü "
"yapacaktır."

