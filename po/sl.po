#. * or the next string for a longer explanation.
#.
#: src/disks/gdu-ata-smart-dialog.c:160
msgid "Reallocated Sector Count"
msgstr "Števec prerazvrščenih sektorjev"

#: src/disks/gdu-ata-smart-dialog.c:161
msgid ""
"Count of remapped sectors. When the hard drive finds a read/write/verification error, it marks the sector as “reallocated” and "
"transfers data to a special reserved area (spare area)"
msgstr ""
"Števec preslikanih sektorjev. Kadar trdi disk najde napako med branjem/pisanjem/potrditvijo, označi sektor kot »prerazvrščen« in "
"prenese podatke v posebno pridržano območje (nadomestno območje)"

