msgid "_Mount"
msgstr "_ເຊື່ອມຕໍ່"

#. Add a RO check button that defaults to RO
#: src/disk-image-mounter/main.c:100
msgid "Set up _read-only mount"
msgstr "ຕັ້ງຄ່າການເຊື່ອມຕໍ່ແບບອ່ານຢ່າງດຽວ (_r)"

#: src/disk-image-mounter/main.c:101
msgid "If checked, the mount will be read-only. This is useful if you don’t want the underlying disk image to be modified"
msgstr "ຖ້າໝາຍຖືກ, ການເຊື່ອມຕໍ່ຈະເປັນແບບອ່ານຢ່າງດຽວ. ນີ້ມີປະໂຫຍດຖ້າທ່ານບໍ່ຕ້ອງການໃຫ້ໄຟລ໌ຮູບພາບດິສຕົ້ນສະບັບຖືກແກ້ໄຂ"

#: src/disk-image-mounter/main.c:142
#, c-format
msgid "Error connecting to udisks daemon: %s (%s, %d)"
msgstr "ຜິດພາດໃນການເຊື່ອມຕໍ່ຫາ udisks daemon: %s (%s, %d)"

#: src/disk-image-mounter/main.c:150
msgid "Attach and mount one or more disk image files."
msgstr "ຕິດຕັ້ງ ແລະ ເຊື່ອມຕໍ່ໄຟລ໌ຮູບພາບດິສໜຶ່ງໄຟລ໌ ຫຼື ຫຼາຍກວ່ານັ້ນ."

#: src/disk-image-mounter/main.c:198
#, c-format
msgid "Cannot open “%s” — maybe the volume isn’t mounted?"
msgstr "ບໍ່ສາມາດເປີດ “%s” ໄດ້ — ບາງທີໂວລຸມອາດຈະຍັງບໍ່ໄດ້ເຊື່ອມຕໍ່?"

#: src/disk-image-mounter/main.c:205
#, c-format
msgid "Error opening “%s”: %m"
msgstr "ຜິດພາດໃນການເປີດ “%s”: %m"

#: src/disk-image-mounter/main.c:226
#, c-format
msgid "Error attaching disk image: %s (%s, %d)"
msgstr "ຜິດພາດໃນການຕິດຕັ້ງຮູບພາບດິສ: %s (%s, %d)"

#: src/disks/gduapplication.c:91
msgid "Stop running jobs?"
msgstr "ຢຸດວຽກທີ່ກຳລັງເຮັດຢູ່ບໍ່?"

#: src/disks/gduapplication.c:93
msgid "Closing now stops the running jobs and leads to a corrupt result."
msgstr "ການປິດຕອນນີ້ຈະຢຸດວຽກທີ່ກຳລັງເຮັດຢູ່ ແລະ ອາດຈະພາໃຫ້ຜົນລັບເສຍຫາຍ."

#: src/disks/gduapplication.c:143
#, c-format
msgid "Error opening %s: %s"
msgstr "ຜິດພາດໃນການເປີດ %s: %s"

#: src/disks/gduapplication.c:150
#, c-format
msgid "Error looking up block device for %s"
msgstr "ຜິດພາດໃນການຊອກຫາອຸປະກອນບລັອກສຳລັບ %s"

#: src/disks/gduapplication.c:172
msgid "Select device"
msgstr "ເລືອກອຸປະກອນ"

#: src/disks/gduapplication.c:173
msgid "Format selected device"
msgstr "ຟໍແມັດອຸປະກອນທີ່ເລືອກ"

#: src/disks/gduapplication.c:174
msgid "Ignored, kept for compatibility"
msgstr "ບໍ່ສົນໃຈ, ເກັບໄວ້ເພື່ອຄວາມເຂົ້າກັນໄດ້"

#: src/disks/gduapplication.c:175
msgid "Restore disk image"
msgstr "ກູ້ຄືນຮູບພາບດິສ"

#: src/disks/gduapplication.c:207
msgid "--format-device must be used together with --block-device\n"
msgstr "--format-device ຕ້ອງໃຊ້ຮ່ວມກັບ --block-device\n"

#: src/disks/gduapplication.c:213
msgid "--format-device must not be used together with --restore-disk-image"
msgstr "--format-device ຕ້ອງບໍ່ໃຊ້ຮ່ວມກັບ --restore-disk-image"

#. Translators: Shown in the About dialog to convey version numbers.
#. *              The first %s is the version of Disks (for example "3.6").
#. *              The second %s is the version of the running udisks daemon (for example "2.0.90").
#. *              The third, fourth and fifth %d are the major, minor and micro versions of libudisks2 that was used when compiling the Disks application (for example 2, 0 and 90).
#.
#: src/disks/gduapplication.c:347
#, c-format
msgid ""
"gnome-disk-utility %s\n"
"UDisks %s (built against %d.%d.%d)"
msgstr ""
"gnome-disk-utility %s\n"
"UDisks %s (ສ້າງຂຶ້ນດ້ວຍ %d.%d.%d)"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:144
msgid "Read Error Rate"
msgstr "ອັດຕາການອ່ານຜິດພາດ"

#: src/disks/gduatasmartdialog.c:145
msgid ""
"Frequency of errors while reading raw data from the disk. A non-zero value indicates a problem with either the disk surface or read/"
"write heads"
msgstr "ຄວາມຖີ່ຂອງຄວາມຜິດພາດໃນຂະນະທີ່ອ່ານຂໍ້ມູນດິບຈາກດິສ. ຄ່າທີ່ບໍ່ແມ່ນສູນ ບົ່ງບອກເຖິງບັນຫາກັບໜ້າດິສ ຫຼື ຫົວອ່ານ/ຂຽນ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:154
msgid "Throughput Performance"
msgstr "ປະສິດທິພາບການສົ່ງຂໍ້ມູນ"

#: src/disks/gduatasmartdialog.c:155
msgid "Average efficiency of the disk"
msgstr "ປະສິດທິພາບໂດຍສະເລ່ຍຂອງດິສ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:162
msgid "Spinup Time"
msgstr "ເວລາເລີ່ມໝຸນ"

#: src/disks/gduatasmartdialog.c:163
msgid "Time needed to spin up the disk"
msgstr "ເວລາທີ່ຕ້ອງການເພື່ອເລີ່ມການໝຸນຂອງດິສ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:170
msgid "Start/Stop Count"
msgstr "ຈຳນວນການເລີ່ມ/ຢຸດ"

#: src/disks/gduatasmartdialog.c:171
msgid "Number of spindle start/stop cycles"
msgstr "ຈຳນວນຮອບວຽນການເລີ່ມ/ຢຸດຂອງແກນໝຸນ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:178
msgid "Reallocated Sector Count"
msgstr "ຈຳນວນເຊັກເຕີທີ່ຖືກຈັດສັນໃໝ່"

#: src/disks/gduatasmartdialog.c:179
msgid ""
"Count of remapped sectors. When the hard drive finds a read/write/verification error, it marks the sector as “reallocated” and "
"transfers data to a special reserved area (spare area)"
msgstr ""
"ຈຳນວນເຊັກເຕີທີ່ຖືກປ່ຽນແປງ. ເມື່ອຮາດໄດຣຟ໌ພົບຂໍ້ຜິດພາດໃນການອ່ານ/ຂຽນ/ກວດສອບ, ມັນຈະໝາຍເຊັກເຕີນັ້ນເປັນ “reallocated” ແລະ ຍ້າຍຂໍ້ມູນໄປທີ່ພື້ນທີ່ສຳຮອງພິເສດ (spare area)"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:188
msgid "Read Channel Margin"
msgstr "ຂອບເຂດຊ່ອງທາງການອ່ານ"

#: src/disks/gduatasmartdialog.c:189
msgid "Margin of a channel while reading data."
msgstr "ຂອບເຂດຂອງຊ່ອງທາງໃນຂະນະທີ່ອ່ານຂໍ້ມູນ."

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:196
msgid "Seek Error Rate"
msgstr "ອັດຕາຄວາມຜິດພາດໃນການຄົ້ນຫາ"

#: src/disks/gduatasmartdialog.c:197
msgid "Frequency of errors while positioning"
msgstr "ຄວາມຖີ່ຂອງຄວາມຜິດພາດໃນຂະນະທີ່ກຳນົດຕຳແໜ່ງ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:204
msgid "Seek Timer Performance"
msgstr "ປະສິດທິພາບຕົວຈັບເວລາການຄົ້ນຫາ"

#: src/disks/gduatasmartdialog.c:205
msgid "Average efficiency of operations while positioning"
msgstr "ປະສິດທິພາບສະເລ່ຍຂອງການດຳເນີນງານໃນຂະນະທີ່ກຳນົດຕຳແໜ່ງ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
#: src/disks/gduatasmartdialog.c:212 src/disks/gduatasmartdialog.c:537
msgid "Power-On Hours"
msgstr "ຊົ່ວໂມງທີ່ເປີດໃຊ້ງານ"

#. Translators: SMART attribute, see http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#.
