#: src/disks/gdu-create-password-page.h:33
msgctxt "Password hint"
msgid "Try changing some letters and numbers."
msgstr "Покушајте да промените нека слова и бројеве."

#: src/disks/gdu-create-password-page.h:35 src/disks/gdu-create-password-page.h:39
msgctxt "Password hint"
msgid "Try changing the password a bit more."
msgstr "Покушајте да још мало промените лозинку."

#: src/disks/gdu-create-password-page.h:37
msgctxt "Password hint"
msgid "Try to avoid some of the words included in the password."
msgstr "Покушајте да избегнете неке од речи укључених у лозинку."

#: src/disks/gdu-create-password-page.h:41
msgctxt "Password hint"
msgid "Try to avoid common words."
msgstr "Покушајте да избегнете честе речи."

#: src/disks/gdu-create-password-page.h:43
msgctxt "Password hint"
msgid "Try to avoid reordering existing words."
msgstr "Покушајте да избегнете премештање постојећих речи."

#: src/disks/gdu-create-password-page.h:45
msgctxt "Password hint"
msgid "Try to use more numbers."
msgstr "Покушајте да користите више бројева."

#: src/disks/gdu-create-password-page.h:47
msgctxt "Password hint"
msgid "Try to use more uppercase letters."
msgstr "Покушајте да користите више великих слова."

#: src/disks/gdu-create-password-page.h:49
msgctxt "Password hint"
msgid "Try to use more lowercase letters."
msgstr "Покушајте да користите више малих слова."

#: src/disks/gdu-create-password-page.h:51
msgctxt "Password hint"
msgid "Try to use more special characters, like punctuation."
msgstr "Покушајте да користите више специјалних знакова, попут интерпункције."

#: src/disks/gdu-create-password-page.h:53
msgctxt "Password hint"
msgid "Try to use a mixture of letters, numbers and punctuation."
msgstr "Покушајте да користите мешавину слова, бројева и интерпункције."

#: src/disks/gdu-create-password-page.h:55
msgctxt "Password hint"
msgid "Try to avoid repeating the same character."
msgstr "Покушајте да избегнете понављање истог знака."

#: src/disks/gdu-create-password-page.h:57
msgctxt "Password hint"
msgid "Try to avoid repeating the same type of character: you need to mix up letters, numbers and punctuation."
msgstr "Покушајте да избегнете понављање исте врсте знакова: треба да помешате слова, бројеве и интерпункцију."

#: src/disks/gdu-create-password-page.h:59
msgctxt "Password hint"
msgid "Try to avoid sequences like 1234 or abcd."
msgstr "Покушајте да избегнете низове попут 1234 или abcd."

#: src/disks/gdu-create-password-page.h:61
msgctxt "Password hint"
msgid "Mix uppercase and lowercase and try to use a number or two."
msgstr "Мешајте велика и мала слова и покушајте да користите број или два."

#: src/disks/gdu-create-password-page.h:63
msgctxt "Password hint"
msgid "Adding more letters, numbers and punctuation will make the password stronger."
msgstr "Додавање више слова, бројева и интерпункције учиниће лозинку јачом."

