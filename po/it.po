msgstr "Monta l'immagine in sola lettura"

#: src/disk-image-mounter/window.ui:60
msgid "Unmount Disk Image"
msgstr "Smonta immagine disco"

#: src/disk-image-mounter/window.ui:61
msgid "Unmount the mounted image"
msgstr "Smonta l'immagine montata"

#: src/disk-image-mounter/window.ui:75
msgid "Edit Contents in Files"
msgstr "Modifica contenuti in File"

#: src/disk-image-mounter/window.ui:76
msgid "Mount the image and allow editing"
msgstr "Monta l'immagine e ne consente la modifica"

#: src/disk-image-mounter/window.ui:95
msgid "Write to Drive"
msgstr "Scrivi sull'unità"

#: src/disk-image-mounter/window.ui:96
msgid "Open in Disks to write the image to a drive"
msgstr "Aprire con Dischi per scrivere l'immagine su un'unità"

#: src/disk-image-mounter/window.ui:109
msgid "Inspect in Disks"
msgstr "Ispeziona in Dischi"

#: src/disk-image-mounter/window.ui:110
msgid "Mount the image and open in Disks"
msgstr "Monta l'immagine e la apre in Dischi"

#: src/disks/gdu-application.c:120
#, c-format
msgid "Error opening %s: %s"
msgstr "Errore nell'apertura di %s: %s"

#: src/disks/gdu-application.c:127
#, c-format
msgid "Error looking up block device for %s"
msgstr "Errore nella ricerca del dispositivo a blocchi per %s"

#: src/disks/gdu-application.c:160
msgid "Select device"
msgstr "Seleziona il dispositivo"

#: src/disks/gdu-application.c:161
msgid "Format selected device"
msgstr "Formatta il dispositivo selezionato"

#: src/disks/gdu-application.c:162
msgid "Show verbose logs, specify up to four times to increase log level"
msgstr ""
"Mostra registri dettagliati, specificare fino a quattro volte per aumentare il "
"livello di dettaglio"

#: src/disks/gdu-application.c:163
msgid "Ignored, kept for compatibility"
msgstr "Ignorato, mantenuto per compatibilità"

#: src/disks/gdu-application.c:164
msgid "Restore disk image"
msgstr "Ripristina l'immagine disco"

#: src/disks/gdu-application.c:197
msgid "--format-device must be used together with --block-device\n"
msgstr "--format-device deve essere utilizzato assieme a --block-device\n"

#: src/disks/gdu-application.c:203
msgid "--format-device must not be used together with --restore-disk-image"
msgstr ""
"--format-device non può essere utilizzato assieme a --restore-disk-image"

