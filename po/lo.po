#: data/gnome-disk-image-mounter.desktop.in:2 src/disk-image-mounter/main.c:54
msgid "Disk Image Mounter"
msgstr "ຕົວເຊື່ອມຕໍ່ຮູບພາບດິສ"

#: data/gnome-disk-image-mounter.desktop.in:3
msgid "Mount Disk Images"
msgstr "ເຊື່ອມຕໍ່ຮູບພາບດິສ"

#: data/gnome-disk-image-writer.desktop.in:2
msgid "Disk Image Writer"
msgstr "ຕົວຂຽນຮູບພາບດິສ"

#: data/gnome-disk-image-writer.desktop.in:3
msgid "Write Disk Images to Devices"
msgstr "ຂຽນຮູບພາບດິສໃສ່ອຸປະກອນ"

#: data/org.gnome.Disks.gschema.xml:6
msgid "Default location for the Create/Restore disk image dialogs"
msgstr "ທີ່ຕັ້ງເລີ່ມຕົ້ນສຳລັບກ່ອງໂຕ້ຕອບສ້າງ/ກູ້ຄືນຮູບພາບດິສ"

#: data/org.gnome.Disks.gschema.xml:7
msgid "Default location for the Create/Restore disk image dialogs. If blank the ~/Documents folder is used."
msgstr "ທີ່ຕັ້ງເລີ່ມຕົ້ນສຳລັບກ່ອງໂຕ້ຕອບສ້າງ/ກູ້ຄືນຮູບພາບດິສ. ຖ້າຫວ່າງເປົ່າ ຈະໃຊ້ໂຟລເດີ ~/Documents."

#: data/org.gnome.Disks.gschema.xml:13
msgid "The number of samples the benchmark will include for the read/write test."
msgstr "ຈຳນວນຕົວຢ່າງທີ່ການວັດແທກປະສິດທິພາບຈະໃຊ້ສຳລັບການທົດສອບອ່ານ/ຂຽນ."

#: data/org.gnome.Disks.gschema.xml:17
msgid "The number of MiB (1048576 bytes) to read/write for each sample."
msgstr "ຈຳນວນ MiB (1048576 ໄບຕ໌) ທີ່ຈະອ່ານ/ຂຽນສຳລັບແຕ່ລະຕົວຢ່າງ."

#: data/org.gnome.Disks.gschema.xml:21
msgid "To enable or disable the write test."
msgstr "ເພື່ອເປີດ ຫຼື ປິດການທົດສອບການຂຽນ."

#: data/org.gnome.Disks.gschema.xml:25
msgid "The number of samples the benchmark will do for the access time test."
msgstr "ຈຳນວນຕົວຢ່າງທີ່ການວັດແທກປະສິດທິພາບຈະໃຊ້ສຳລັບການທົດສອບເວລາເຂົ້າເຖິງ."

#: data/org.gnome.DiskUtility.appdata.xml.in:7 data/org.gnome.DiskUtility.desktop.in:2 src/disks/gduwindow.c:1107
#: src/disks/ui/about-dialog.ui:10 src/disks/ui/disks.ui:28
msgid "Disks"
msgstr "ດິສ"

#: data/org.gnome.DiskUtility.appdata.xml.in:8
msgid "Disk management utility for GNOME"
msgstr "ໂປຣແກຣມຈັດການດິສສຳລັບ GNOME"

#: data/org.gnome.DiskUtility.appdata.xml.in:10
msgid "Disks provides an easy way to inspect, format, partition, and configure disks and block devices."
msgstr "ດິສ ຊ່ວຍໃຫ້ສາມາດກວດສອບ, ຟໍແມັດ, ແບ່ງພາທິຊັນ ແລະ ຕັ້ງຄ່າດິສ ແລະ ອຸປະກອນບລັອກໄດ້ຢ່າງງ່າຍດາຍ."

#: data/org.gnome.DiskUtility.appdata.xml.in:14
msgid "Using Disks, you can view SMART data, manage devices, benchmark physical disks, and image USB sticks."
msgstr "ການໃຊ້ ດິສ, ທ່ານສາມາດເບິ່ງຂໍ້ມູນ SMART, ຈັດການອຸປະກອນ, ວັດແທກປະສິດທິພາບດິສຈິງ ແລະ ສ້າງຮູບພາບໃຫ້ກັບ USB."

#: data/org.gnome.DiskUtility.appdata.xml.in:22
msgid "Partition and format disks"
msgstr "ແບ່ງພາທິຊັນ ແລະ ຟໍແມັດດິສ"

#: data/org.gnome.DiskUtility.appdata.xml.in:26
msgid "Inspect drive speed and health status"
msgstr "ກວດສອບຄວາມໄວ ແລະ ສະຖານະສຸຂະພາບຂອງໄດຣຟ໌"

#: data/org.gnome.DiskUtility.appdata.xml.in:30
msgid "Manage your storage devices"
msgstr "ຈັດການອຸປະກອນເກັບຂໍ້ມູນຂອງທ່ານ"

#. developer_name tag deprecated with Appstream 1.0
#: data/org.gnome.DiskUtility.appdata.xml.in:44
msgid "The GNOME Project"
msgstr "ໂຄງການ GNOME"

#: data/org.gnome.DiskUtility.desktop.in:3
msgid "Manage Drives and Media"
msgstr "ຈັດການໄດຣຟ໌ ແລະ ສື່"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.DiskUtility.desktop.in:5
msgid "disk;drive;volume;harddisk;hdd;disc;cdrom;dvd;partition;iso;image;backup;restore;benchmark;raid;luks;encryption;S.M.A.R.T.;smart;"
msgstr "disk;drive;volume;harddisk;hdd;disc;cdrom;dvd;partition;iso;image;backup;restore;benchmark;raid;luks;encryption;S.M.A.R.T.;smart;"

#: src/disk-image-mounter/main.c:52
msgid "An error occurred"
msgstr "ເກີດຂໍ້ຜິດພາດ"

#: src/disk-image-mounter/main.c:73
msgid "Allow writing to the image"
msgstr "ອະນຸຍາດໃຫ້ຂຽນໃສ່ຮູບພາບ"

#: src/disk-image-mounter/main.c:88
msgid "Select Disk Image(s) to Mount"
msgstr "ເລືອກຮູບພາບດິສເພື່ອເຊື່ອມຕໍ່"

